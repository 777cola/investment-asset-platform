<view class="bg-canvas">
  <view class="bg-gradient"></view>
  <view class="bg-grid"></view>
</view>

<view class="app-shell">
  <header class="navbar">
    <view class="navbar-brand">
      <view class="brand-logo"><span>KH</span></view>
      <view class="brand-text">
        <view class="logo-title">恺皓资本</view>
        <view class="logo-subtitle">KaiHao Capital</view>
      </view>
    </view>
    <view class="navbar-controls">
      <button class="icon-btn" bindtap="onLogout" title="退出登录">
        <text>退出</text>
      </button>
    </view>
  </header>

  <view id="flash-message" class="flash hidden" role="status" aria-live="polite"></view>

  <main class="workspace">
    <section id="main-view" class="content-area">
      <view class="content-inner">
        <view class="section-header">
          <view>
            <view class="section-title">管理控制台</view>
            <view class="section-subtitle">欢迎回来，{{username}}</view>
          </view>
        </view>

        <view class="grid-3">
          <view class="card" bindtap="navigateToUserManagement">
            <view class="card-header">
              <view class="card-title">用户管理</view>
              <view class="card-subtitle">投资者信息管理</view>
            </view>
            <view class="card-body">
              <view class="info-list">
                <view class="info-item">
                  <view class="info-label">投资者数量</view>
                  <view class="info-value">{{investorCount}}</view>
                </view>
                <view class="info-item">
                  <view class="info-label">总资产</view>
                  <view class="info-value">¥{{totalAssetValue}}</view>
                </view>
              </view>
            </view>
          </view>

          <view class="card" bindtap="navigateToProductManagement">
            <view class="card-header">
              <view class="card-title">产品管理</view>
              <view class="card-subtitle">投资产品管理</view>
            </view>
            <view class="card-body">
              <view class="info-list">
                <view class="info-item">
                  <view class="info-label">产品数量</view>
                  <view class="info-value">{{productCount}}</view>
                </view>
                <view class="info-item">
                  <view class="info-label">管理资产</view>
                  <view class="info-value">¥{{totalProductValue}}</view>
                </view>
              </view>
            </view>
          </view>

          <view class="card" bindtap="navigateToValueUpdate">
            <view class="card-header">
              <view class="card-title">价值更新</view>
              <view class="card-subtitle">更新投资价值</view>
            </view>
            <view class="card-body">
              <view class="info-list">
                <view class="info-item">
                  <view class="info-label">上次更新</view>
                  <view class="info-value">{{lastUpdateDate}}</view>
                </view>
                <view class="info-item">
                  <view class="info-label">总收益率</view>
                  <view class="info-value {{totalReturnRate >= 0 ? 'up' : 'down'}}">{{totalReturnRate}}%</view>
                </view>
              </view>
            </view>
          </view>

          <view class="card" bindtap="navigateToAssetOverview">
            <view class="card-header">
              <view class="card-title">资产全览</view>
              <view class="card-subtitle">资产分布概览</view>
            </view>
            <view class="card-body">
              <view class="info-list">
                <view class="info-item">
                  <view class="info-label">总投资</view>
                  <view class="info-value">¥{{totalInvested}}</view>
                </view>
                <view class="info-item">
                  <view class="info-label">总收益</view>
                  <view class="info-value {{totalProfit >= 0 ? 'up' : 'down'}}">¥{{totalProfit}}</view>
                </view>
              </view>
            </view>
          </view>

          <view class="card" bindtap="navigateToInterestRecords">
            <view class="card-header">
              <view class="card-title">利息发放</view>
              <view class="card-subtitle">利息发放记录</view>
            </view>
            <view class="card-body">
              <view class="info-list">
                <view class="info-item">
                  <view class="info-label">发放次数</view>
                  <view class="info-value">{{interestRecordCount}}</view>
                </view>
                <view class="info-item">
                  <view class="info-label">总发放金额</view>
                  <view class="info-value">¥{{totalInterestAmount}}</view>
                </view>
              </view>
            </view>
          </view>

          <view class="card" bindtap="navigateToDataManagement">
            <view class="card-header">
              <view class="card-title">数据管理</view>
              <view class="card-subtitle">导入导出数据</view>
            </view>
            <view class="card-body">
              <view class="info-list">
                <view class="info-item">
                  <view class="info-label">数据版本</view>
                  <view class="info-value">{{dataVersion}}</view>
                </view>
                <view class="info-item">
                  <view class="info-label">操作</view>
                  <view class="info-value">导入/导出</view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </section>
  </main>
</view>