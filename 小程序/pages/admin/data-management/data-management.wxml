<view class="bg-canvas">
  <view class="bg-gradient"></view>
  <view class="bg-grid"></view>
</view>

<view class="app-shell">
  <header class="navbar">
    <view class="navbar-brand">
      <view class="brand-logo"><span>KH</span></view>
      <view class="brand-text">
        <view class="logo-title">恺皓资本</view>
        <view class="logo-subtitle">KaiHao Capital</view>
      </view>
    </view>
    <view class="navbar-controls">
      <button class="icon-btn" bindtap="onBack" title="返回">
        <text>返回</text>
      </button>
    </view>
  </header>

  <view id="flash-message" class="flash hidden" role="status" aria-live="polite"></view>

  <main class="workspace">
    <section id="main-view" class="content-area">
      <view class="content-inner">
        <view class="section-header">
          <view>
            <view class="section-title">数据管理</view>
            <view class="section-subtitle">导入导出数据</view>
          </view>
        </view>

        <view class="grid-2">
          <view class="card">
            <view class="card-header">
              <view class="card-title">导出数据</view>
              <view class="card-subtitle">将当前数据导出为JSON文件</view>
            </view>
            <view class="card-body">
              <view class="info-list">
                <view class="info-item">
                  <view class="info-label">投资者数量</view>
                  <view class="info-value">{{investorCount}}</view>
                </view>
                <view class="info-item">
                  <view class="info-label">产品数量</view>
                  <view class="info-value">{{productCount}}</view>
                </view>
                <view class="info-item">
                  <view class="info-label">数据版本</view>
                  <view class="info-value">{{dataVersion}}</view>
                </view>
              </view>
              <button class="btn-primary btn-block" bindtap="onExportData" style="margin-top: 16px;">
                <text>导出JSON</text>
              </button>
            </view>
          </view>

          <view class="card">
            <view class="card-header">
              <view class="card-title">导入数据</view>
              <view class="card-subtitle">从JSON文件导入数据</view>
            </view>
            <view class="card-body">
              <view class="helper-note">
                <text>导入数据将覆盖当前所有数据，请谨慎操作。</text>
              </view>
              <button class="btn-secondary btn-block" bindtap="onImportData" style="margin-top: 16px;">
                <text>选择JSON文件</text>
              </button>
            </view>
          </view>
        </view>

        <view class="card" style="margin-top: 20px;">
          <view class="card-header">
            <view class="card-title">数据重置</view>
            <view class="card-subtitle">重置为默认数据</view>
          </view>
          <view class="card-body">
            <view class="helper-note">
              <text>重置将清除所有现有数据，恢复为默认状态。此操作不可撤销。</text>
            </view>
            <button class="btn-danger btn-block" bindtap="onResetData" style="margin-top: 16px;">
              <text>重置数据</text>
            </button>
          </view>
        </view>
      </view>
    </section>
  </main>
</view>