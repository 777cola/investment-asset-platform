<view class="bg-canvas">
  <view class="bg-gradient"></view>
  <view class="bg-grid"></view>
</view>

<view class="app-shell">
  <header class="navbar">
    <view class="navbar-brand">
      <view class="brand-logo"><span>KH</span></view>
      <view class="brand-text">
        <view class="logo-title">恺皓资本</view>
        <view class="logo-subtitle">KaiHao Capital</view>
      </view>
    </view>
    <view class="navbar-controls">
      <button class="icon-btn" bindtap="onBack" title="返回">
        <text>返回</text>
      </button>
    </view>
  </header>

  <view id="flash-message" class="flash hidden" role="status" aria-live="polite"></view>

  <main class="workspace">
    <section id="main-view" class="content-area">
      <view class="content-inner">
        <view class="section-header">
          <view>
            <view class="section-title">产品管理</view>
            <view class="section-subtitle">投资产品管理</view>
          </view>
          <button class="btn-primary" bindtap="onAddProduct">
            <text>添加产品</text>
          </button>
        </view>

        <view class="investor-grid">
          <view wx:for="{{products}}" wx:key="id" class="investor-card">
            <view class="investor-card-header">
              <view class="investor-avatar">{{item.name.charAt(0)}}</view>
              <view>
                <view class="investor-card-name">{{item.name}}</view>
                <view class="investor-card-id">{{item.code}}</view>
              </view>
            </view>
            <view class="investor-card-body">
              <view class="investor-detail">
                <view class="detail-label">平台</view>
                <view class="detail-value">{{item.platform}}</view>
              </view>
              <view class="investor-detail">
                <view class="detail-label">创建日期</view>
                <view class="detail-value">{{item.createdAt}}</view>
              </view>
              <view class="investor-detail">
                <view class="detail-label">最新价值</view>
                <view class="detail-value">¥{{item.latestValue}}</view>
              </view>
            </view>
            <view class="investor-card-actions">
              <button class="btn-ghost btn-sm" bindtap="onEditProduct" data-id="{{item.id}}">
                <text>编辑</text>
              </button>
              <button class="btn-ghost btn-sm" bindtap="onDeleteProduct" data-id="{{item.id}}">
                <text>删除</text>
              </button>
            </view>
          </view>
        </view>

        <!-- 添加/编辑产品表单 -->
        <view wx:if="{{showForm}}" class="card" style="margin-top: 20px;">
          <view class="card-header">
            <view class="card-title">{{isEditing ? '编辑产品' : '添加产品'}}</view>
          </view>
          <view class="card-body">
            <view class="form-grid">
              <view class="form-field">
                <label class="form-label">产品名称</label>
                <input 
                  class="text-input" 
                  placeholder="请输入产品名称" 
                  bindinput="onNameInput"
                  value="{{formData.name}}"
                />
              </view>
              <view class="form-field">
                <label class="form-label">产品代码</label>
                <input 
                  class="text-input" 
                  placeholder="请输入产品代码" 
                  bindinput="onCodeInput"
                  value="{{formData.code}}"
                />
              </view>
              <view class="form-field">
                <label class="form-label">平台</label>
                <input 
                  class="text-input" 
                  placeholder="请输入平台名称" 
                  bindinput="onPlatformInput"
                  value="{{formData.platform}}"
                />
              </view>
              <view class="form-field">
                <label class="form-label">创建日期</label>
                <input 
                  class="text-input" 
                  placeholder="YYYY-MM-DD" 
                  bindinput="onCreatedAtInput"
                  value="{{formData.createdAt}}"
                />
              </view>
              <view class="form-field col-span-2">
                <label class="form-label">备注</label>
                <textarea 
                  class="textarea-input" 
                  placeholder="请输入备注信息" 
                  bindinput="onNotesInput"
                  value="{{formData.notes}}"
                ></textarea>
              </view>
            </view>
            <view class="form-actions" style="margin-top: 16px;">
              <button class="btn-ghost" bindtap="onCancelForm">
                <text>取消</text>
              </button>
              <button class="btn-primary" bindtap="onSaveProduct">
                <text>保存</text>
              </button>
            </view>
          </view>
        </view>
      </view>
    </section>
  </main>
</view>