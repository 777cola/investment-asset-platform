<view class="bg-canvas">
  <view class="bg-gradient"></view>
  <view class="bg-grid"></view>
</view>

<view class="app-shell">
  <header class="navbar">
    <view class="navbar-brand">
      <view class="brand-logo"><span>KH</span></view>
      <view class="brand-text">
        <view class="logo-title">恺皓资本</view>
        <view class="logo-subtitle">KaiHao Capital</view>
      </view>
    </view>
    <view class="navbar-controls">
      <button class="icon-btn" bindtap="onBack" title="返回">
        <text>返回</text>
      </button>
    </view>
  </header>

  <view id="flash-message" class="flash hidden" role="status" aria-live="polite"></view>

  <main class="workspace">
    <section id="main-view" class="content-area">
      <view class="content-inner">
        <view class="section-header">
          <view>
            <view class="section-title">资产全览</view>
            <view class="section-subtitle">资产分布概览</view>
          </view>
        </view>

        <view class="kpi-grid-4">
          <view class="kpi-card highlighted">
            <view class="kpi-label">总资产</view>
            <view class="kpi-value">¥{{totalAssetValue}}</view>
            <view class="kpi-caption">最新估值</view>
          </view>
          <view class="kpi-card">
            <view class="kpi-label">总投资</view>
            <view class="kpi-value">¥{{totalInvested}}</view>
            <view class="kpi-caption">累计投入</view>
          </view>
          <view class="kpi-card">
            <view class="kpi-label">总收益</view>
            <view class="kpi-value {{totalProfit >= 0 ? 'up' : 'down'}}">¥{{totalProfit}}</view>
            <view class="kpi-caption">总收益</view>
          </view>
          <view class="kpi-card">
            <view class="kpi-label">总收益率</view>
            <view class="kpi-value {{totalReturnRate >= 0 ? 'up' : 'down'}}">{{totalReturnRate}}%</view>
            <view class="kpi-caption">年化收益</view>
          </view>
        </view>

        <view class="grid-2" style="margin-top: 20px;">
          <view class="card">
            <view class="card-header">
              <view class="card-title">投资者资产分布</view>
            </view>
            <view class="card-body">
              <view class="table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>投资者</th>
                      <th>投资金额</th>
                      <th>最新价值</th>
                      <th>收益率</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr wx:for="{{investorAssets}}" wx:key="id">
                      <td>{{item.name}}</td>
                      <td>¥{{item.invested}}</td>
                      <td>¥{{item.value}}</td>
                      <td class="{{item.returnRate >= 0 ? 'up' : 'down'}}">{{item.returnRate}}%</td>
                    </tr>
                  </tbody>
                </table>
              </view>
            </view>
          </view>

          <view class="card">
            <view class="card-header">
              <view class="card-title">产品资产分布</view>
            </view>
            <view class="card-body">
              <view class="table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>产品</th>
                      <th>平台</th>
                      <th>最新价值</th>
                      <th>占比</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr wx:for="{{productAssets}}" wx:key="id">
                      <td>{{item.name}}</td>
                      <td>{{item.platform}}</td>
                      <td>¥{{item.value}}</td>
                      <td>{{item.percentage}}%</td>
                    </tr>
                  </tbody>
                </table>
              </view>
            </view>
          </view>
        </view>

        <view class="card" style="margin-top: 20px;">
          <view class="card-header">
            <view class="card-title">平台资产分布</view>
          </view>
          <view class="card-body">
            <view class="info-list">
              <view wx:for="{{platformAssets}}" wx:key="platform" class="info-item">
                <view class="info-label">{{item.platform}}</view>
                <view class="info-value">
                  <text>¥{{item.value}} ({{item.percentage}}%)</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </section>
  </main>
</view>