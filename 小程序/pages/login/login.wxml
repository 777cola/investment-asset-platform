<view class="bg-canvas">
  <view class="bg-gradient"></view>
  <view class="bg-grid"></view>
</view>

<view class="app-shell">
  <header class="navbar">
    <view class="navbar-brand">
      <view class="brand-logo"><span>KH</span></view>
      <view class="brand-text">
        <view class="logo-title">恺皓资本</view>
        <view class="logo-subtitle">KaiHao Capital</view>
      </view>
    </view>
  </header>

  <view id="flash-message" class="flash hidden" role="status" aria-live="polite"></view>

  <main class="workspace">
    <section id="main-view" class="content-area">
      <view class="auth-wrap">
        <view class="auth-hero">
          <view class="auth-hero-title">
            <text class="highlight-blue">专业</text> 资产管理
            <text class="highlight-orange">平台</text>
          </view>
          <view class="auth-hero-desc">
            为投资者提供清晰、透明的资产概览，
            帮助您实时掌握投资动态与价值变化。
          </view>
          <view class="auth-mode-badge">
            <text>安全登录</text>
          </view>
        </view>
        
        <view class="auth-form-panel">
          <view class="form-field">
            <label class="form-label">用户名</label>
            <input 
              class="text-input" 
              placeholder="请输入用户名" 
              bindinput="onUsernameInput"
              value="{{username}}"
            />
          </view>
          <view class="form-field">
            <label class="form-label">密码</label>
            <input 
              class="text-input" 
              placeholder="请输入密码" 
              password="true" 
              bindinput="onPasswordInput"
              value="{{password}}"
            />
          </view>
          <view class="form-actions">
            <button 
              class="btn-primary btn-block" 
              bindtap="onLogin"
            >
              登录
            </button>
          </view>
          <view class="helper-note">
            <text>演示账号：用户名：演示，密码：123456</text>
          </view>
        </view>
      </view>
    </section>
  </main>
</view>