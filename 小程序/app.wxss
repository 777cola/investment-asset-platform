/* 恺皓资本资产管理平台 - 小程序优化样式 */

/* 基础样式 */
page {
  background-color: #0a0e14;
  color: #f9fafb;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  min-height: 100vh;
  line-height: 1.6;
  overflow-x: hidden;
  font-size: 16px;
}

view, text, input, button, image {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

/* 背景效果 */
.bg-canvas {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.bg-gradient {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: radial-gradient(ellipse 70% 45% at 20% -10%, rgba(0,82,255,0.12), transparent), radial-gradient(ellipse 55% 40% at 90% 20%, rgba(255,125,0,0.08), transparent), radial-gradient(ellipse 50% 35% at 60% 110%, rgba(255,153,51,0.06), transparent);
}

.bg-grid {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px);
  background-size: 48px 48px;
  opacity: 0.3;
}

/* APP 外壳 */
.app-shell {
  position: relative;
  z-index: 1;
  width: 100%;
  padding: 0 20px;
  padding-bottom: 64px;
}

/* 导航栏 */
.navbar {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  height: 68px;
  padding: 0 24px;
  margin: 20px 0 24px;
  background-color: rgba(10,14,20,0.9);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 24px;
  box-shadow: 0 6px 24px rgba(0,0,0,0.12);
}

.navbar-brand {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 14px;
}

.brand-logo {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 44px;
  height: 44px;
  border-radius: 16px;
  background: linear-gradient(135deg, #0052ff, #ff7d00);
  overflow: hidden;
}

.brand-logo text {
  color: white;
  font-weight: 800;
  font-size: 16px;
}

.logo-title {
  font-size: 17px;
  font-weight: 800;
}

.logo-subtitle {
  font-size: 11px;
  color: rgba(249,250,251,0.35);
  text-transform: uppercase;
}

.navbar-controls {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10px;
}

/* 图标按钮 */
.icon-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,0.1);
  background-color: rgba(31,41,55,0.88);
  color: rgba(249,250,251,0.65);
}

/* 工作区布局 */
.workspace {
  display: flex;
  flex-direction: row;
  gap: 20px;
}

.sidebar {
  width: 310px;
  flex-shrink: 0;
  background-color: rgba(17,24,39,0.96);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 24px;
  overflow: hidden;
}

.sidebar-scroll {
  padding: 22px;
}

.sidebar-section {
  margin-bottom: 22px;
}

.sidebar-label {
  font-size: 11px;
  font-weight: 800;
  color: rgba(249,250,251,0.35);
  text-transform: uppercase;
  margin-bottom: 14px;
}

.content-area {
  flex: 1;
  background-color: rgba(17,24,39,0.96);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 24px;
  overflow: hidden;
  min-height: 620px;
}

.content-inner {
  padding: 28px;
}

/* KPI 卡片网格 */
.kpi-grid-4 {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
}

.kpi-card {
  padding: 18px 20px;
  border-radius: 16px;
  border: 1px solid rgba(255,255,255,0.1);
  background-color: rgba(17,24,39,0.98);
}

.kpi-card.highlighted {
  border-color: #ff7d00;
  background: linear-gradient(145deg, rgba(255,125,0,0.08), rgba(17,24,39,0.98));
}

.kpi-label {
  font-size: 12px;
  font-weight: 700;
  color: rgba(249,250,251,0.35);
  text-transform: uppercase;
  margin-bottom: 10px;
}

.kpi-value {
  font-size: 22px;
  font-weight: 800;
  font-family: 'Courier New', monospace;
}

.kpi-caption {
  margin-top: 8px;
  font-size: 12px;
  color: rgba(249,250,251,0.35);
}

/* 卡片组件 */
.card {
  border-radius: 16px;
  border: 1px solid rgba(255,255,255,0.1);
  background-color: rgba(17,24,39,0.98);
  overflow: hidden;
}

.card-header {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18px;
  padding: 20px 22px 0;
  margin-bottom: 16px;
}

.card-title {
  font-size: 16px;
  font-weight: 800;
}

.card-subtitle {
  font-size: 13px;
  color: rgba(249,250,251,0.65);
  margin-top: 4px;
}

.card-body {
  padding: 20px 22px;
}

/* 按钮样式 */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 42px;
  padding: 0 20px;
  border-radius: 16px;
  border: none;
  font-size: 14px;
  font-weight: 700;
  background: linear-gradient(135deg, #0052ff, #0041c7);
  color: white;
  box-shadow: 0 6px 28px rgba(0,82,255,0.3);
}

.btn-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 34px;
  padding: 0 14px;
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,0.1);
  background: transparent;
  color: rgba(249,250,251,0.65);
  font-size: 13px;
  font-weight: 600;
}

.btn-sm {
  height: 34px;
  padding: 0 14px;
  font-size: 13px;
}

.btn-block {
  width: 100%;
  justify-content: center;
}

/* 表单样式 */
.form-field {
  display: flex;
  flex-direction: column;
  gap: 7px;
}

.form-label {
  font-size: 13px;
  font-weight: 700;
  color: rgba(249,250,251,0.65);
}

.text-input {
  width: 100%;
  height: 44px;
  padding: 0 16px;
  background-color: rgba(31,41,55,0.75);
  border: 1px solid rgba(255,255,255,0.16);
  border-radius: 12px;
  color: #f9fafb;
  font-size: 14px;
}

.form-actions {
  display: flex;
  flex-direction: row;
  gap: 12px;
  margin-top: 8px;
}

/* 认证页面 */
.auth-wrap {
  display: grid;
  grid-template-columns: 1.15fr 0.85fr;
  gap: 22px;
  padding: 32px;
  min-height: 520px;
  align-items: center;
}

.auth-hero {
  padding: 48px 42px;
  background: linear-gradient(145deg, rgba(0,82,255,0.08), rgba(255,125,0,0.04));
  border: 1px solid rgba(0,82,255,0.45);
  border-radius: 24px;
}

.auth-hero-title {
  font-size: 32px;
  font-weight: 900;
  line-height: 1.05;
  margin-bottom: 18px;
}

.auth-hero-title .highlight-blue {
  color: #3385ff;
}

.auth-hero-title .highlight-orange {
  color: #ff9933;
}

.auth-hero-desc {
  font-size: 16px;
  color: rgba(249,250,251,0.65);
  line-height: 1.75;
  margin-bottom: 24px;
}

.auth-mode-badge {
  display: inline-flex;
  align-items: center;
  height: 38px;
  padding: 0 16px;
  border-radius: 9999px;
  border: 1px solid rgba(34,197,94,0.35);
  background-color: rgba(34,197,94,0.1);
  font-size: 13px;
  color: #22c55e;
  margin-bottom: 18px;
}

.auth-form-panel {
  display: grid;
  gap: 18px;
  padding: 32px;
  background-color: rgba(17,24,39,0.98);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 24px;
}

.helper-note {
  padding: 14px 16px;
  border-radius: 12px;
  border: 1px solid rgba(255,125,0,0.4);
  background-color: rgba(255,125,0,0.05);
  font-size: 13px;
  color: rgba(249,250,251,0.65);
}

/* 投资者头部 */
.investor-header {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22px;
  padding: 28px 32px;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  background: linear-gradient(145deg, rgba(0,82,255,0.05), rgba(255,125,0,0.02), transparent);
}

.investor-name {
  font-size: 28px;
  font-weight: 900;
  margin-bottom: 12px;
}

.investor-meta {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 8px;
}

.pill {
  display: inline-flex;
  align-items: center;
  height: 30px;
  padding: 0 12px;
  border-radius: 9999px;
  border: 1px solid rgba(255,255,255,0.1);
  background-color: rgba(31,41,55,0.88);
  color: rgba(249,250,251,0.65);
  font-size: 13px;
  font-weight: 600;
}

.pill-blue {
  background: linear-gradient(135deg, #0052ff, #0041c7);
  border-color: transparent;
  color: white;
  box-shadow: 0 6px 28px rgba(0,82,255,0.3);
}

/* 信息列表 */
.info-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.info-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 14px 16px;
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,0.1);
  background-color: rgba(31,41,55,0.88);
}

.info-label {
  font-size: 13px;
  color: rgba(249,250,251,0.65);
}

.info-value {
  font-size: 14px;
  font-weight: 700;
  color: #f9fafb;
  text-align: right;
}

/* 投资者网格 */
.investor-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 18px;
}

.investor-card {
  background-color: rgba(17,24,39,0.98);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 24px;
  overflow: hidden;
}

.investor-card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 14px;
  padding: 20px 22px;
  background: linear-gradient(145deg, rgba(0,82,255,0.07), rgba(255,125,0,0.03), transparent);
  border-bottom: 1px solid rgba(255,255,255,0.1);
}

.investor-avatar {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: linear-gradient(135deg, #0052ff, #ff7d00);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  font-size: 18px;
  flex-shrink: 0;
}

.investor-card-name {
  font-weight: 800;
  font-size: 16px;
}

.investor-card-id {
  font-size: 12px;
  color: rgba(249,250,251,0.35);
  font-family: 'Courier New', monospace;
  margin-top: 3px;
}

.investor-card-body {
  padding: 16px 22px;
}

.investor-detail {
  display: flex;
  flex-direction: row;
  margin-bottom: 10px;
  font-size: 14px;
}

.investor-detail:last-child {
  margin-bottom: 0;
}

.detail-label {
  color: rgba(249,250,251,0.65);
  width: 90px;
  flex-shrink: 0;
}

.detail-value {
  color: #f9fafb;
  font-family: 'Courier New', monospace;
  font-size: 13px;
}

.investor-card-actions {
  display: flex;
  flex-direction: row;
  gap: 8px;
  padding: 14px 22px;
  border-top: 1px solid rgba(255,255,255,0.1);
  background-color: rgba(31,41,55,0.88);
}

/* 投资分配项 */
.alloc-item {
  padding: 20px 22px;
  border-radius: 16px;
  border: 1px solid rgba(255,255,255,0.1);
  background-color: rgba(17,24,39,0.98);
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.alloc-top {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14px;
}

.alloc-name {
  font-weight: 800;
  font-size: 15px;
}

.alloc-focus {
  font-size: 13px;
  color: rgba(249,250,251,0.65);
  margin-top: 4px;
}

.alloc-code {
  font-size: 12px;
  color: rgba(249,250,251,0.35);
  font-family: 'Courier New', monospace;
  margin-top: 3px;
}

.badge {
  display: inline-flex;
  align-items: center;
  height: 24px;
  padding: 0 10px;
  border-radius: 9999px;
  font-size: 11px;
  font-weight: 700;
}

.badge-blue {
  background-color: rgba(0,82,255,0.14);
  color: #66a3ff;
  border: 1px solid rgba(0,82,255,0.25);
}

.alloc-bar {
  height: 8px;
  border-radius: 9999px;
  background-color: rgba(255,255,255,0.1);
  overflow: hidden;
}

.alloc-bar-fill {
  height: 100%;
  border-radius: 9999px;
  background: linear-gradient(90deg, #0052ff, #ff7d00);
}

.alloc-metrics {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
}

.alloc-metric-label {
  font-size: 11px;
  color: rgba(249,250,251,0.35);
  text-transform: uppercase;
}

.alloc-metric-value {
  font-size: 14px;
  font-weight: 800;
  font-family: 'Courier New', monospace;
  margin-top: 4px;
}

/* 通知项 */
.notice-item {
  padding: 16px 18px;
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,0.1);
  background-color: rgba(31,41,55,0.88);
}

.notice-title {
  font-size: 14px;
  font-weight: 700;
}

.notice-date {
  font-size: 12px;
  color: rgba(249,250,251,0.35);
  font-family: 'Courier New', monospace;
}

.notice-body {
  font-size: 13px;
  color: rgba(249,250,251,0.65);
  margin-top: 6px;
  line-height: 1.65;
}

/* 提示消息 */
.flash {
  margin-bottom: 18px;
  padding: 14px 18px;
  border-radius: 16px;
  border: 1px solid rgba(255,255,255,0.1);
  background-color: rgba(17,24,39,0.96);
  font-size: 14px;
}

.flash.hidden {
  display: none;
}

.flash.success {
  border-color: rgba(34,197,94,0.45);
  background-color: rgba(34,197,94,0.08);
  color: #22c55e;
}

.flash.error {
  border-color: rgba(239,68,68,0.45);
  background-color: rgba(239,68,68,0.08);
  color: #ef4444;
}

/* 网格布局 */
.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

/* 表格样式 */
.table-wrap {
  overflow-x: auto;
}

table {
  width: 100%;
  border-collapse: collapse;
}

th, td {
  padding: 14px 18px;
  text-align: left;
  border-bottom: 1px solid rgba(255,255,255,0.1);
  vertical-align: middle;
}

th {
  font-size: 12px;
  font-weight: 800;
  color: rgba(249,250,251,0.35);
  text-transform: uppercase;
  background-color: rgba(31,41,55,0.88);
  white-space: nowrap;
}

td {
  font-size: 14px;
  color: #f9fafb;
}

/* 颜色状态 */
.up {
  color: #22c55e;
}

.down {
  color: #ef4444;
}

/* 响应式设计 */
@media (max-width: 1024px) {
  .workspace {
    flex-direction: column;
  }
  
  .sidebar {
    width: 100%;
  }
  
  .auth-wrap {
    grid-template-columns: 1fr;
  }
  
  .kpi-grid-4 {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 768px) {
  .app-shell {
    padding: 0 14px;
  }
  
  .navbar {
    padding: 0 16px;
    height: 58px;
    margin: 12px 0 16px;
  }
  
  .logo-subtitle {
    display: none;
  }
  
  .content-inner {
    padding: 20px;
  }
  
  .kpi-grid-4 {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .auth-wrap {
    padding: 20px;
    grid-template-columns: 1fr;
  }
  
  .auth-hero {
    padding: 28px 24px;
  }
}
